FROM debian:bookworm

# Устанавливаем Python 3.11 (родной для Bookworm) и GUI зависимости
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-dev \
    python3-tk tk-dev tcl-dev \
    libx11-dev libxft-dev gcc \
    && rm -rf /var/lib/apt/lists/*

# Устанавливаем PyInstaller и psutil
# В Debian Bookworm (Python 3.11) требуется флаг --break-system-packages из-за PEP 668
RUN pip3 install --break-system-packages pyinstaller psutil

# Проверяем что tkinter работает
RUN python3 -c "import tkinter; print('tkinter OK')"

WORKDIR /build

