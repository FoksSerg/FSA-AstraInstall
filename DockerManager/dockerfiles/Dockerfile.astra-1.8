FROM debian:bookworm

# Устанавливаем Python 3.11 (родной для Bookworm) и GUI зависимости
# КРИТИЧНО: Устанавливаем полные пакеты Tcl/Tk (не только dev) для PyInstaller
# КРИТИЧНО: Добавляем зависимости для компиляции Pillow (jpeg, zlib, freetype и т.д.)
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-dev \
    python3-tk tk-dev tcl-dev \
    tcl tcl8.6 tk tk8.6 \
    tcl-tclreadline \
    blt \
    libx11-dev libxft-dev gcc \
    libjpeg-dev zlib1g-dev libfreetype6-dev \
    liblcms2-dev libopenjp2-7-dev libtiff5-dev libwebp-dev \
    wmctrl \
    && rm -rf /var/lib/apt/lists/*

# Устанавливаем PyInstaller и psutil
# В Debian Bookworm (Python 3.11) требуется флаг --break-system-packages из-за PEP 668
RUN pip3 install --break-system-packages pyinstaller psutil pystray pillow

# Проверяем что tkinter работает
RUN python3 -c "import tkinter; print('tkinter OK')"

WORKDIR /build

